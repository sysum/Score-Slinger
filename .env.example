# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Supabase — server-side only (never expose to client)
# Project Settings > API > service_role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase — client-side (safe to expose, used by Expo app)
# Project Settings > API > anon/public key
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# The public domain this app is served from (no protocol)
# Local dev:   localhost:5000
# Production:  yourapp.vercel.app
EXPO_PUBLIC_DOMAIN=localhost:5000

# Comma-separated allowed CORS origins for production (leave unset locally)
# ALLOWED_ORIGINS=https://yourapp.vercel.app
