# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/scoreslinger
# Supabase: found in Project Settings > Database > Connection string (Transaction mode)
DATABASE_URL=postgresql://user:password@localhost:5432/scoreslinger

# The public domain this app is served from (no protocol)
# Local dev:   localhost:5000
# Production:  yourdomain.vercel.app
EXPO_PUBLIC_DOMAIN=localhost:5000

# Comma-separated list of allowed CORS origins (for production)
# Leave unset for local dev — localhost is always allowed
# ALLOWED_ORIGINS=https://yourdomain.vercel.app
